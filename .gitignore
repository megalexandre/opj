# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Ignore bundler config.
/.bundle
/vendor/bundle
/lib/bundler/man

# Ignore the default SQLite database.
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-shm
/db/*.sqlite3-wal

# Ignore all logfiles and temp files.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore uploaded files in development.
/storage/*
!/storage/.keep

# Ignore database configuration and encryption keys.
/config/database.yml
/config/master.key
/config/credentials/*.key
/.env*

# Ignore asset output directories.
/public/assets
/public/packs
/public/packs-test

# Ignore Node.js and package manager artifacts.
/node_modules
/yarn-error.log
/package-lock.json

# Ignore OS and IDE generated files.
.DS_Store
.project
.idea/
.vscode/
*.swp
*.swo


/volume/*